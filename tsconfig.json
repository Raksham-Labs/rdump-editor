{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["vite/client", "node"],
    "paths": {
      "@rakshamlabs/rdump-editor": ["./src/index.ts"],
      "@rakshamlabs/rdump-editor/styles.css": ["./playground/src/noop.css"]
    }
  },
  "include": ["src", "tests", "playground/src", "vite.config.ts", "playground/vite.config.ts"]
}
